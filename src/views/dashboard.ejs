<%- include('templates/header', {title: t('dashboard.title') }) %>

    <div
        class="min-h-screen md:flex bg-[#F9FBFA] dark:bg-[#061621] text-slate-900 dark:text-slate-100 font-sans transition-colors duration-300">

        <%- include('templates/sidebar') %>

            <div class="flex-1">
                <%- include('templates/header_page', { title: t('dashboard.title') }) %>
                    <main class="max-w-[1600px] mx-auto p-8">

                        <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
                            <div>
                                <h1 class="text-2xl font-bold tracking-tight"><%= t('dashboard.executive_summary') %></h1>
                                <p class="text-slate-500 dark:text-slate-400"><%= t('dashboard.summary_desc') %>
                                </p>
                            </div>
                            <div class="flex gap-3">
                                <button
                                    class="px-4 py-2 text-sm font-semibold border border-slate-200 dark:border-slate-800 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors bg-white dark:bg-transparent"><%= t('dashboard.export_report') %></button>
                                <button
                                    class="px-4 py-2 text-sm font-semibold bg-[#001E2B] dark:bg-emerald-600 text-white rounded-lg hover:opacity-90 transition-opacity shadow-md"><%= t('dashboard.new_record') %></button>
                            </div>
                        </header>

                        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8" aria-labelledby="metrics-title">
                            <h2 id="metrics-title" class="sr-only"><%= t('dashboard.main_metrics') %></h2>
                            <div
                                class="bg-white dark:bg-[#091E2C] border border-slate-200 dark:border-slate-800 p-5 rounded-xl shadow-sm">
                                <div class="flex justify-between items-start mb-4">
                                    <div class="p-2 bg-emerald-50 dark:bg-emerald-500/10 rounded-lg text-emerald-600">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                            stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-5.25v9" />
                                        </svg>
                                    </div>
                                    <span class="text-xs font-bold text-emerald-500">+4.5%</span>
                                </div>
                                <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium"><%= t('dashboard.active_skus') %></h3>
                                <p class="text-2xl font-bold mt-1">4,521</p>
                            </div>
                            <div
                                class="bg-white dark:bg-[#091E2C] border border-slate-200 dark:border-slate-800 p-5 rounded-xl shadow-sm border-l-4 border-l-red-500">
                                <div class="flex justify-between items-start mb-4">
                                    <div class="p-2 bg-red-50 dark:bg-red-500/10 rounded-lg text-red-600">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                            stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                                        </svg>
                                    </div>
                                </div>
                                <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium"><%= t('dashboard.critical_stock') %></h3>
                                <p class="text-2xl font-bold mt-1">12</p>
                            </div>
                            <div
                                class="bg-white dark:bg-[#091E2C] border border-slate-200 dark:border-slate-800 p-5 rounded-xl shadow-sm">
                                <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-4"><%= t('dashboard.inventory_turnover') %>
                                </h3>
                                <p class="text-2xl font-bold">82%</p>
                                <div
                                    class="w-full bg-slate-100 dark:bg-slate-800 h-1.5 rounded-full mt-3 overflow-hidden">
                                    <div class="bg-blue-500 h-full w-[82%]"></div>
                                </div>
                            </div>
                            <div
                                class="bg-white dark:bg-[#091E2C] border border-slate-200 dark:border-slate-800 p-5 rounded-xl shadow-sm">
                                <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-4"><%= t('dashboard.revenue_today') %>
                                </h3>
                                <p class="text-2xl font-bold">$1,240.00</p>
                                <p class="text-xs text-slate-400 mt-2 italic"><%= t('dashboard.based_on_sales') %></p>
                            </div>
                        </section>

                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

                            <section
                                class="lg:col-span-2 bg-white dark:bg-[#091E2C] border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm overflow-hidden" aria-labelledby="chart-title">
                                <header
                                    class="p-6 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between bg-slate-50/50 dark:bg-transparent">
                                    <h2 id="chart-title" class="font-bold text-lg"><%= t('dashboard.stock_trend') %></h2>
                                    <div class="flex gap-2">
                                                class="w-2 h-2 rounded-full bg-emerald-500"></span> <%= t('dashboard.incomes') %></span>
                                                class="w-2 h-2 rounded-full bg-blue-500"></span> <%= t('dashboard.outcomes') %></span>
                                    </div>
                                </header>
                                <div class="p-6 h-[350px]">
                                    <canvas id="mainChart"></canvas>
                                </div>
                            </section>

                            <section
                                class="bg-white dark:bg-[#091E2C] border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm flex flex-col" aria-labelledby="activity-title">
                                <header class="p-6 border-b border-slate-100 dark:border-slate-800">
                                    <h2 id="activity-title" class="font-bold text-lg"><%= t('dashboard.recent_activity') %></h2>
                                </header>
                                <div class="flex-1 overflow-y-auto">
                                    <article
                                        class="p-4 border-b border-slate-50 dark:border-slate-800 flex items-center gap-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                        <div
                                            class="w-10 h-10 rounded bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-xs" aria-hidden="true">
                                            📦</div>
                                        <div class="flex-1">
                                            <h3 class="text-sm font-bold italic truncate">Filtro de Aceite XZ-2</h3>
                                            <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold">
                                                <%= t('dashboard.stock_entry') %>
                                            </p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-sm font-bold text-emerald-500" aria-label="Incremento de 50">+50</p>
                                            <time datetime="14:20" class="text-[10px] text-slate-400">14:20 PM</time>
                                        </div>
                                    </article>
                                    <article
                                        class="p-4 border-b border-slate-50 dark:border-slate-800 flex items-center gap-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                        <div
                                            class="w-10 h-10 rounded bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-xs" aria-hidden="true">
                                            ⚙️</div>
                                        <div class="flex-1">
                                            <h3 class="text-sm font-bold italic truncate">Pastillas de Freno Brembo</h3>
                                            <p class="text-[10px] text-slate-500 uppercase tracking-widest font-bold">
                                                <%= t('dashboard.counter_sale') %></p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-sm font-bold text-red-500" aria-label="Decremento de 2">-2</p>
                                            <time datetime="12:05" class="text-[10px] text-slate-400">12:05 PM</time>
                                        </div>
                                    </article>
                                </div>
                                <a href="#"
                                    class="p-4 text-center text-xs font-bold text-emerald-600 hover:bg-emerald-50 dark:hover:bg-emerald-500/5 transition-colors"><%= t('dashboard.view_all_history') %></a>
                            </section>
                        </div>

                    </main>

            </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <%- include('templates/footer', {js: 'dashboard.js' }) %>