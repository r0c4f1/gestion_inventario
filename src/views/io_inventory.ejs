<%- include('templates/header', {title: t('io_inventory.page_title') }) %>

    <div
        class="min-h-screen flex bg-[#F9FBFA] dark:bg-[#061621] text-slate-900 dark:text-slate-100 font-sans transition-colors duration-300">

        <%- include('templates/sidebar') %>

            <div id="main-content" class="flex-1 min-w-0 transition-all duration-500">

                <%- include('templates/header_page', { title: t('io_inventory.header_title') }) %>

                    <main class="p-6 md:p-10 space-y-8">

                        <!-- ZONA DE CARGA EXCEL (DROPZONE) -->
                        <div
                            class="bg-white dark:bg-[#091E2C] rounded-[2.5rem] p-8 border border-slate-200 dark:border-slate-800 shadow-sm">
                            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">

                                <div class="lg:col-span-1 space-y-4">
                                    <h2 class="text-xs font-black uppercase tracking-[0.2em] text-emerald-500">
                                        <%= t('io_inventory.import_massive') %>
                                    </h2>
                                    <p
                                        class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-medium italic">
                                        <%- t('io_inventory.import_desc') %>
                                    </p>

                                    <select name="type_of_movement" id="type_of_movement"
                                        class="w-full px-4 py-3 text-[10px] font-black uppercase tracking-widest outline-none bg-slate-50 dark:bg-[#0D2A3E] border border-slate-200 dark:border-slate-700 rounded-2xl">
                                        <option value=""><%= t('io_inventory.select_type') %></option>
                                        <option value="IN"><%= t('io_inventory.type_in') %></option>
                                        <option value="OUT"><%= t('io_inventory.type_out') %></option>
                                    </select>

                                </div>

                                <!-- INPUT TYPE FILE ESTILIZADO -->
                                <div class="lg:col-span-2">
                                    <label for="excel-upload" class="relative group cursor-pointer">
                                        <div
                                            class="border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-4xl p-10 bg-slate-50/50 dark:bg-[#0D2A3E]/30 flex flex-col items-center justify-center gap-4 group-hover:border-emerald-500/50 group-hover:bg-emerald-500/5 transition-all duration-500">
                                            <div
                                                class="w-14 h-14 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-500 border border-emerald-500/20 group-hover:scale-110 transition-transform">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                    stroke-width="2" stroke="currentColor" class="w-7 h-7">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                                                </svg>
                                            </div>
                                            <div class="text-center">
                                                <span
                                                    class="block text-sm font-black italic uppercase tracking-tighter">
                                                    <%= t('io_inventory.click_drag') %>
                                                </span>
                                                <span
                                                    class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1">
                                                    <%= t('io_inventory.supported_formats') %>
                                                </span>
                                            </div>
                                        </div>
                                        <input type="file" id="excel-upload" accept=".xlsx, .xls, .csv" class="hidden">
                                    </label>
                                </div>

                            </div>
                        </div>

                        <!-- SECCIÓN DE LA TABLA -->
                        <div
                            class="bg-white dark:bg-[#091E2C] rounded-[3rem] border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                            <div
                                class="px-10 py-8 border-b border-slate-100 dark:border-slate-800/50 flex flex-col md:flex-row md:items-center justify-between gap-6">
                                <div class="flex items-center gap-4">
                                    <div class="w-2 h-8 bg-emerald-500 rounded-full"></div>
                                    <div>
                                        <h2 class="text-xl font-black italic uppercase tracking-tighter">
                                            <%= t('io_inventory.latest') %> <span class="text-emerald-500">
                                                    <%= t('io_inventory.movements') %>
                                                </span>
                                        </h2>
                                        <p class="text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em]">
                                            <%= t('io_inventory.history_record') %>
                                        </p>
                                    </div>
                                </div>

                                <!-- BUSCADOR / FILTRO RÁPIDO -->
                                <div
                                    class="flex bg-slate-50 dark:bg-[#0D2A3E] rounded-2xl border border-slate-200 dark:border-slate-700 p-1 w-full md:w-80">
                                    <span class="px-4 flex items-center text-slate-400">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                            stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                                        </svg>
                                    </span>
                                    <input type="text" placeholder="<%= t('io_inventory.search_placeholder') %>"
                                        class="bg-transparent flex-1 px-2 py-3 text-[10px] font-black uppercase tracking-widest outline-none">
                                </div>
                            </div>

                            <!-- CONTENEDOR PARA TU TABLA GRID.JS -->
                            <div class="p-4">
                                <div id="table-movimientos-container"
                                    class="min-h-[400px] w-full rounded-4xl bg-slate-50/30 dark:bg-[#061621]/20 border-2 border-dashed border-slate-200 dark:border-slate-800 flex items-center justify-center">
                                    <div class="text-center opacity-40">
                                        <p class="text-xs font-black italic uppercase tracking-[0.3em]">
                                            <%= t('io_inventory.loading_data') %>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- BOTONES DE PROCESAMIENTO (FOOTER) -->
                        <div class="flex justify-end pt-4">
                            <button
                                class="px-16 py-5 bg-emerald-500 hover:bg-emerald-600 text-slate-900 rounded-3xl font-black uppercase tracking-widest text-xs shadow-2xl shadow-emerald-500/30 transition-all transform hover:-translate-y-1 active:scale-95">
                                <%= t('io_inventory.process_selected') %>
                            </button>
                        </div>

                    </main>
            </div>
    </div>

    <%- include('templates/footer', { js: 'io_inventory' }) %>