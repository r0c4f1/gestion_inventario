<div id="modal-modelo" class="fixed inset-0 z-70 hidden flex items-center justify-center p-4">

    <div class="absolute inset-0 bg-slate-950/40 backdrop-blur-md animate-overlay-fade" onclick="closeModeloModal()">
    </div>

    <div class="relative bg-white dark:bg-[#091E2C] w-full max-w-md overflow-hidden rounded-4xl shadow-2xl border border-slate-200 dark:border-slate-800 flex flex-col animate-modal-entry"
        id="content-modelo">

        <div
            class="px-6 py-5 border-b bg-stone-400 border-slate-100 dark:border-slate-800/50 dark:bg-[#091f2e] flex items-center justify-between">
            <h2 class="text-lg font-black italic uppercase tracking-tighter text-slate-900 dark:text-white">
                <%= t('modals.new') %> <span class="text-emerald-500">
                        <%= t('modals.model') %>
                    </span>
            </h2>
            <button onclick="closeModeloModal()"
                class="p-2 rounded-xl hover:bg-red-500/10 text-black cursor-pointer dark:text-white hover:text-red-500 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                    stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="p-6 space-y-5">
            <div class="space-y-1.5">
                <label>
                    <h4 class="text-md font-black italic text-slate-400 ml-1">
                        <%= t('modals.reference') %>
                    </h4>
                </label>
                <div
                    class="flex items-center bg-slate-50 dark:bg-slate-800/40 rounded-xl border border-slate-100 dark:border-slate-800/50 p-1">
                    <input type="text" disabled value="MOD-AUTO-00X"
                        class="bg-transparent flex-1 px-3 py-2 text-xs font-mono text-slate-500 italic">
                </div>
            </div>

            <div class="space-y-1.5">
                <label>
                    <h4 class="text-md font-black italic text-slate-400 ml-1">
                        <%= t('modals.brands_label') %>
                    </h4>
                </label>
                <div
                    class="flex items-center bg-slate-50 dark:bg-[#0D2A3E] rounded-xl border border-slate-200 dark:border-slate-700 p-1 focus-within:ring-2 focus-within:ring-emerald-500/20 transition-all">
                    <input type="text" readonly value="CAT-0"
                        class="w-12 text-center bg-emerald-500/10 text-emerald-500 font-mono text-[9px] font-bold rounded-lg py-2">
                    <select
                        class="flex-1 bg-transparent px-3 py-2 text-xs text-slate-700 dark:text-slate-200 outline-none font-bold italic">
                        <option value="">
                            <%= t('modals.select_placeholder') %>
                        </option>
                    </select>
                </div>
            </div>

            <div class="space-y-1.5">
                <label>
                    <h4 class="text-md font-black italic text-slate-400 ml-1">
                        <%= t('modals.model_name_label') %>
                    </h4>
                </label>
                <input type="text" placeholder="<%= t('modals.model_name_placeholder') %>"
                    class="w-full bg-slate-50 dark:bg-[#0D2A3E] border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm font-bold italic text-emerald-600 dark:text-emerald-400 outline-none focus:ring-2 focus:ring-emerald-500/20">
            </div>
        </div>

        <div
            class="px-6 py-5 bg-slate-50/50 dark:bg-slate-800/20 border-t border-slate-100 dark:border-slate-800/50 flex justify-end gap-3">
            <button
                class="px-4 py-2 text-md cursor-pointer font-black uppercase text-slate-400 hover:text-red-500 transition-colors">
                <%= t('common.cancel') %>
            </button>
            <button
                class="px-6 py-3 bg-emerald-500 text-md cursor-pointer hover:bg-emerald-600 text-slate-900 rounded-xl font-black uppercase text-[10px] shadow-lg shadow-emerald-500/20 transition-transform active:scale-95">
                <%= t('common.save') %>
            </button>
        </div>
    </div>
</div>
<script>
    function openModeloModal() {
        const modal = document.getElementById('modal-modelo');
        const content = document.getElementById('content-modelo');

        modal.classList.remove('hidden');
        content.style.animation = "modalEntry 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards";
    }

    function closeModeloModal() {
        const modal = document.getElementById('modal-modelo');
        const content = document.getElementById('content-modelo');

        // Aplicamos animación de salida manualmente
        content.style.animation = "modalEntry 1s ease-in reverse forwards";

        // Esperamos a que termine la animación para ocultar el contenedor
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 50);
    }
</script>