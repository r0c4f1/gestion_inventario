<div id="main-content" class="transition-all duration-500 pl-64">
</div>

<script>
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('main-content');
    const toggleBtn = document.getElementById('toggle-sidebar');
    const toggleIcon = document.getElementById('toggle-icon');
    const sidebarTexts = document.querySelectorAll('.sidebar-text');
    const sidebarLogo = document.getElementById('sidebar-logo');

    toggleBtn.addEventListener('click', () => {
        // 1. Alternar ancho del sidebar
        sidebar.classList.toggle('w-64');
        sidebar.classList.toggle('w-20');

        // 2. Alternar margen del contenido principal
        mainContent.classList.toggle('pl-64');
        mainContent.classList.toggle('pl-20');

        // 3. Rotar el icono 180 grados
        toggleIcon.classList.toggle('rotate-180');

        // 4. Ocultar/Mostrar textos y logo de forma sutil
        sidebarTexts.forEach(text => {
            text.classList.toggle('opacity-0');
            text.classList.toggle('hidden');
        });
        sidebarLogo.classList.toggle('opacity-0');
    });
</script>